}
.page-footer a {
  color: var(--gold-mid);
  text-decoration: none;
  margin: 0 0.5rem;
}
.page-footer a:hover { text-decoration: underline; }
@media (max-width: 640px) {
  .content-card { padding: 1.8rem 1.3rem; }
