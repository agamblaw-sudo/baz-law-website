<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #f0f6ff;
  --navy-dark: #10293f;
  --navy-deep: #1a3a5c;
  --gold: #b8860b;
  --gold-mid: #c9a84c;
  --text-dark: #1a3a5c;
  --text-muted: #4a6fa5;
  --white: #ffffff;
}
body {
  font-family: 'Heebo', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: var(--navy);
  color: var(--text-dark);
  direction: rtl;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
/* Explicit font inheritance for all headings */
