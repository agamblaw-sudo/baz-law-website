<style>
/* ══════════════════════════════
   FOOTER
══════════════════════════════ */

/* ── Outer shell ── */
footer {
  background: #0b1f30;
  border-top: 2px solid rgba(201,168,76,0.3);
  direction: rtl;
}

/* ── Inner container (aligns grid + bottom bar to same max-width) ── */
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 2.5rem 2rem;
}

/* ══════════════════════
   4-Column Grid
══════════════════════ */
.footer-grid {
  display: grid;
  /* Col widths: brand(1.7) | nav(1) | expertise(1) | contact(1.5) */
  grid-template-columns: 1.7fr 1fr 1fr 1.5fr;
  gap: 2rem 3.5rem;
  margin-bottom: 3.5rem;
}

/* ── Column 1: Brand / Logo ── */
.footer-brand {
  display: flex;
  flex-direction: column;
  align-items: flex-start;  /* RTL start = right edge */
}

.footer-brand .footer-logo-img {
  height: 95px;
  width: 320px;
  object-fit: contain;
  display: block;
  margin-bottom: 1.1rem;
  mix-blend-mode: normal;
  background: #0b1f30;
  padding: 4px 0;
}

.footer-brand-about {
  font-size: 0.87rem;
  color: rgba(240,246,255,0.52);
  line-height: 1.85;
  max-width: 255px;
  text-align: justify;
}

/* ── Column headings (shared by nav cols + contact) ── */
.footer-col h4,
.footer-contact h4 {
  font-family: 'Heebo', Arial, sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--gold-mid);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
  padding-bottom: 0.55rem;
  border-bottom: 1px solid rgba(201,168,76,0.22);
}

/* ── Columns 2 & 3: Navigation lists ── */
.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.footer-col ul li a {
  text-decoration: none;
  color: rgba(240,246,255,0.58);
  font-size: 0.87rem;
  line-height: 1.4;
  transition: color 0.18s;
  display: inline-block;
}
.footer-col ul li a:hover { color: var(--gold-mid); }

/* ── Column 4: Contact ── */
.footer-contact-item {
  display: flex;
  align-items: flex-start;
  /* SVG is flex-child 1 → placed at RTL-start (right) */
  /* text is flex-child 2 → placed to the left of icon  */
  gap: 0.65rem;
  margin-bottom: 0.85rem;
  font-size: 0.86rem;
  color: rgba(240,246,255,0.58);
}

.footer-contact-item svg {
  flex-shrink: 0;
  margin-top: 2px;
  /* icon sits at RTL-start = right, text flows to its left */
}

.footer-contact-item a,
.footer-contact-item span { line-height: 1.6; }

.footer-contact-item a {
  color: rgba(240,246,255,0.58);
  text-decoration: none;
  transition: color 0.18s;
}
.footer-contact-item a:hover { color: var(--gold-mid); }

.footer-nav-link {
  display: flex;
  align-items: center;
  gap: 0.65rem;          /* matches .footer-contact-item gap */
  margin-top: 0.55rem;
  margin-bottom: 0.85rem;/* matches .footer-contact-item spacing */
  font-size: 0.86rem;    /* matches .footer-contact-item font-size */
  font-weight: 600;
  color: var(--gold-mid) !important;
  text-decoration: none;
  transition: opacity 0.18s;
}
.footer-nav-link svg {
  flex-shrink: 0;
  /* no margin-top: icon is single-line → center alignment is exact */
}
.footer-nav-link:hover { opacity: 0.75; }

/* ══════════════════════
   Bottom Bar
══════════════════════ */
.footer-bottom {
  border-top: 1px solid rgba(201,168,76,0.18);
  padding-top: 1.4rem;
  display: flex;
  align-items: center;
  justify-content: space-between;  /* copyright at RTL-right, links at RTL-left */
  gap: 1rem;
  flex-wrap: wrap;
  font-size: 0.77rem;
}

/* Copyright — RTL-start (right) */
.footer-copyright {
  color: rgba(240,246,255,0.32);
  white-space: nowrap;
  line-height: 1.5;
  flex-shrink: 0;
}

/* Legal links group — RTL-end (left) */
.footer-bottom-end {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  flex-wrap: wrap;
}

a.footer-bottom-links {
  color: rgba(240,246,255,0.4);
  text-decoration: none;
  transition: color 0.18s;
  white-space: nowrap;
  font-size: 0.78rem;
}
a.footer-bottom-links:hover { color: var(--gold-mid); }
.footer-sep { color: rgba(240,246,255,0.18); font-size: 0.78rem; }

.footer-admin-link {
  color: rgba(240,246,255,0.15);
  text-decoration: none;
  font-size: 0.68rem;
  transition: color 0.18s;
  white-space: nowrap;
}
.footer-admin-link:hover { color: var(--gold-mid); }

/* WhatsApp phone links */
.footer-wa-link {
  color: rgba(240,246,255,0.58) !important;
  text-decoration: none;
  transition: color 0.18s;
}
.footer-wa-link:hover { color: var(--gold-mid) !important; }

/* ══════════════════════
   Responsive Breakpoints
══════════════════════ */

/* Tablet: 2 columns */
@media (min-width: 640px) and (max-width: 1023px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 2rem;
  }
  .footer-brand-about { max-width: 100%; }
}

/* Mobile: single column */
@media (max-width: 639px) {
  .footer-inner { padding: 2.5rem 1.25rem 1.5rem; }
  .footer-grid {
    grid-template-columns: 1fr;
    gap: 2.25rem;
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .footer-brand { align-items: center; }
  .footer-brand .footer-logo-img { margin: 0 auto 1rem; height: 95px; width: 320px; }
  .footer-brand-about { max-width: 100%; text-align: center; }
  .footer-col ul { align-items: center; }
  .footer-contact-item { justify-content: center; }
  .footer-bottom {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    font-size: 0.72rem;
  }
  .footer-bottom-end { flex-direction: column; align-items: center; gap: 0.6rem; }
  .footer-copyright { white-space: normal; text-align: center; }
}
/* Navigation buttons */
.nav-btns {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 0.5rem;
}

.nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.88rem;
  font-weight: 600;
  padding: 0.65rem 1.3rem;
  border-radius: 8px;
  text-decoration: none;
  width: fit-content;
  transition: background 0.2s, transform 0.2s;
  font-family: Arial, sans-serif;
  color: white;
}
.nav-btn:hover { transform: translateY(-1px); }

.nav-btn-google { background: #1a73e8; }
.nav-btn-google:hover { background: #1557b0; }

.nav-btn-waze { background: #33ccff; }
.nav-btn-waze:hover { background: #00b3e6; }

.nav-btn-moovit { background: #f15a22; }
.nav-btn-moovit:hover { background: #d44b1a; }

.footer-links { display: none; }
.footer-logo  { display: none; }
.footer-text  { display: none; }


</style>

